# Copy this file to `.env` and edit values directly or through `python harness.py dashboard`.
#
# After installing requirements, also install Playwright browsers:
#   pip install -r requirements.txt
#   python -m playwright install chromium

# --- API ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
HARNESS_MODEL=gpt-4o
API_REQUEST_TIMEOUT_SECONDS=600
API_RECOVERY_POLL_SECONDS=15
API_MAX_RECOVERY_WAIT_SECONDS=0
API_RETRY_BACKOFF_SECONDS=5
API_RETRY_MAX_BACKOFF_SECONDS=60

# --- Runtime ---
HARNESS_WORKSPACE=./workspace
HARNESS_ARTIFACT_ROOT=.ai-harness
HARNESS_DASHBOARD_HOST=127.0.0.1
HARNESS_DASHBOARD_PORT=8765

# --- Orchestration ---
ENABLE_PLANNER=true
MAX_HARNESS_ROUNDS=8

# --- Quality Gates ---
RELEASE_READY_SCORE=9.0
CORE_SCORE_FLOOR=8.5
STRICT_CORRECTNESS_FLOOR=9.0
STRICT_OPERABILITY_FLOOR=9.0
MAX_CRITICAL_BUGS=0
MAX_MAJOR_BUGS=0
REQUIRE_FULL_SPEC_COVERAGE=true
REQUIRE_BROWSER_VERIFICATION=true
BLOCK_PLACEHOLDER_UI=true

# --- Context ---
COMPRESS_THRESHOLD=80000
RESET_THRESHOLD=150000
MAX_AGENT_ITERATIONS=60
